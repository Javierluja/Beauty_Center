# ── Backend ─────────────────────────────────────────────────────
APP_ID=beauty-center
APP_SECRET=                   # Clave secreta para firmar sesiones JWT (ej. una frase larga y segura)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=                 # URL de conexión MySQL (mysql://user:pass@host:port/db)

# ── Admin Config ───────────────────────────────────────────────
ADMIN_EMAIL=admin@beautycenter.com # Email de referencia del administrador
